require cpc.Prelude as eo;
require open cpc.theories.Builtin cpc.theories.Arith;

constant symbol Seq : τ ({|eo::Type|} ⤳ {|eo::Type|});
constant symbol Char : Set;
symbol String ≔ Seq Char;
constant symbol RegLan : Set;
constant symbol {|seq.empty|} : Π T: Set, τ (Seq T);
sequential symbol {|$seq_empty|} : Π T: Set, τ (@{|eo::quote|} {|eo::Type|} T ⤳ T);
constant symbol {|str.len|} : Π T: Set, τ (Seq T ⤳ {|eo::Int|});
constant symbol {|str.++|} : Π T: Set, τ (Seq T ⤳ (Seq T ⤳ Seq T));
constant symbol {|str.substr|} : Π T: Set, τ (Seq T ⤳ ({|eo::Int|} ⤳ ({|eo::Int|} ⤳ Seq T)));
constant symbol {|str.contains|} : Π T: Set, τ (Seq T ⤳ (Seq T ⤳ Bool));
constant symbol {|str.replace|} : Π T: Set, τ (Seq T ⤳ (Seq T ⤳ (Seq T ⤳ Seq T)));
constant symbol {|str.indexof|} : Π T: Set, τ (Seq T ⤳ (Seq T ⤳ ({|eo::Int|} ⤳ {|eo::Int|})));
constant symbol {|str.at|} : Π T: Set, τ (Seq T ⤳ ({|eo::Int|} ⤳ Seq T));
constant symbol {|str.prefixof|} : Π T: Set, τ (Seq T ⤳ (Seq T ⤳ Bool));
constant symbol {|str.suffixof|} : Π T: Set, τ (Seq T ⤳ (Seq T ⤳ Bool));
constant symbol {|str.rev|} : Π T: Set, τ (Seq T ⤳ Seq T);
constant symbol {|str.update|} : Π T: Set, τ (Seq T ⤳ ({|eo::Int|} ⤳ (Seq T ⤳ Seq T)));
constant symbol {|str.to_lower|} : τ ({|eo::String|} ⤳ {|eo::String|});
constant symbol {|str.to_upper|} : τ ({|eo::String|} ⤳ {|eo::String|});
constant symbol {|str.to_code|} : τ ({|eo::String|} ⤳ {|eo::Int|});
constant symbol {|str.from_code|} : τ ({|eo::Int|} ⤳ {|eo::String|});
constant symbol {|str.is_digit|} : τ ({|eo::String|} ⤳ Bool);
constant symbol {|str.to_int|} : τ ({|eo::String|} ⤳ {|eo::Int|});
constant symbol {|str.from_int|} : τ ({|eo::Int|} ⤳ {|eo::String|});
constant symbol {|str.<|} : τ ({|eo::String|} ⤳ ({|eo::String|} ⤳ Bool));
constant symbol {|str.<=|} : τ ({|eo::String|} ⤳ ({|eo::String|} ⤳ Bool));
constant symbol {|str.replace_all|} : Π T: Set, τ (Seq T ⤳ (Seq T ⤳ (Seq T ⤳ Seq T)));
constant symbol {|str.replace_re|} : τ ({|eo::String|} ⤳ (RegLan ⤳ ({|eo::String|} ⤳ {|eo::String|})));
constant symbol {|str.replace_re_all|} : τ ({|eo::String|} ⤳ (RegLan ⤳ ({|eo::String|} ⤳ {|eo::String|})));
constant symbol {|str.indexof_re|} : τ ({|eo::String|} ⤳ (RegLan ⤳ ({|eo::Int|} ⤳ {|eo::Int|})));
constant symbol {|re.allchar|} : τ RegLan;
constant symbol {|re.none|} : τ RegLan;
constant symbol {|re.all|} : τ RegLan;
constant symbol {|str.to_re|} : τ ({|eo::String|} ⤳ RegLan);
symbol {|@re.empty|} ≔ @APP _ _ {|str.to_re|} "";
constant symbol {|re.*|} : τ (RegLan ⤳ RegLan);
constant symbol {|re.+|} : τ (RegLan ⤳ RegLan);
constant symbol {|re.^|} : τ ({|eo::Int|} ⤳ (RegLan ⤳ RegLan));
constant symbol {|re.opt|} : τ (RegLan ⤳ RegLan);
constant symbol {|re.comp|} : τ (RegLan ⤳ RegLan);
constant symbol {|re.range|} : τ ({|eo::String|} ⤳ ({|eo::String|} ⤳ RegLan));
constant symbol {|re.++|} : τ (RegLan ⤳ (RegLan ⤳ RegLan));
constant symbol {|re.inter|} : τ (RegLan ⤳ (RegLan ⤳ RegLan));
constant symbol {|re.union|} : τ (RegLan ⤳ (RegLan ⤳ RegLan));
constant symbol {|re.diff|} : τ (RegLan ⤳ (RegLan ⤳ RegLan));
constant symbol {|re.loop|} : τ ({|eo::Int|} ⤳ ({|eo::Int|} ⤳ (RegLan ⤳ RegLan)));
constant symbol {|str.in_re|} : τ ({|eo::String|} ⤳ (RegLan ⤳ Bool));
constant symbol {|seq.unit|} : Π T: Set, τ (T ⤳ Seq T);
constant symbol {|seq.nth|} : Π T: Set, τ (Seq T ⤳ ({|eo::Int|} ⤳ T));
symbol {|seq.len|} [T : Set] ≔ @{|str.len|} T;
symbol {|seq.++|} [T : Set] ≔ @{|str.++|} T;
symbol {|seq.extract|} [T : Set] ≔ @{|str.substr|} T;
symbol {|seq.contains|} [T : Set] ≔ @{|str.contains|} T;
symbol {|seq.replace|} [T : Set] ≔ @{|str.replace|} T;
symbol {|seq.replace_all|} [T : Set] ≔ @{|str.replace_all|} T;
symbol {|seq.indexof|} [T : Set] ≔ @{|str.indexof|} T;
symbol {|seq.prefixof|} [T : Set] ≔ @{|str.prefixof|} T;
symbol {|seq.suffixof|} [T : Set] ≔ @{|str.suffixof|} T;
symbol {|seq.rev|} [T : Set] ≔ @{|str.rev|} T;
symbol {|seq.update|} [T : Set] ≔ @{|str.update|} T;
symbol {|seq.at|} [T : Set] ≔ @{|str.at|} T;
constant symbol {|@re_unfold_pos_component|} : τ {|eo::String|} → τ RegLan → τ {|eo::Int|} → τ {|eo::String|};
constant symbol {|@strings_deq_diff|} : Π T: Set, τ (Seq T) → τ (Seq T) → τ {|eo::Int|};
constant symbol {|@strings_stoi_result|} : τ {|eo::String|} → τ ({|eo::Int|} ⤳ {|eo::Int|});
constant symbol {|@strings_stoi_non_digit|} : τ {|eo::String|} → τ {|eo::Int|};
constant symbol {|@strings_itos_result|} : τ {|eo::Int|} → τ ({|eo::Int|} ⤳ {|eo::Int|});
constant symbol {|@strings_num_occur|} : Π T: Set, τ (Seq T) → τ (Seq T) → τ {|eo::Int|};
constant symbol {|@strings_num_occur_re|} : τ {|eo::String|} → τ RegLan → τ {|eo::Int|};
constant symbol {|@strings_occur_index|} : Π T: Set, τ (Seq T) → τ (Seq T) → τ ({|eo::Int|} ⤳ {|eo::Int|});
constant symbol {|@strings_occur_index_re|} : τ {|eo::String|} → τ RegLan → τ ({|eo::Int|} ⤳ {|eo::Int|});
constant symbol {|@strings_replace_all_result|} : Π T: Set, τ (Seq T) → τ ({|eo::Int|} ⤳ Seq T);
constant symbol {|@witness_string_length|} : Π T: Set, τ ({|eo::Int|} ⤳ ({|eo::Int|} ⤳ T));
