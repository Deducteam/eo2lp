symbol {|$arith_mk_zero|} (T : Set) ≔ @{|eo::ite|} {|eo::Int|} {|eo::Rat|} (@{|eo::is_eq|} {|eo::Type|} {|eo::Type|} T {|eo::Int|}) 0 (@{|eo::requires|} {|eo::Type|} {|eo::Type|} {|eo::Rat|} T {|eo::Rat|} ({|eo::mkrat|} 0 1));
