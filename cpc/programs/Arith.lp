symbol {|$arith_eval_sub|} [U : Set] [T : Set] (x : τ U) (y : τ T) ≔ @{|$arith_eval_add|} U T x (@{|eo::neg|} T y);
symbol {|$arith_eval_mul|} [T : Set] [U : Set] (x : τ T) (y : τ U) ≔ @{|eo::ite|} ({|eo::Rat|} ⊍ {|eo::Rat|}) (?? (@{|eo::eq|} U {|eo::Rat|} y (@{|eo::to_q|} U y)) ({|eo::Rat|} ⊍ {|eo::Rat|}) (T ⊍ U)) (@{|eo::eq|} T {|eo::Rat|} x (@{|eo::to_q|} T x)) (@{|eo::mul|} {|eo::Rat|} {|eo::Rat|} (@{|eo::to_q|} T x) (@{|eo::to_q|} U y)) (@{|eo::ite|} ({|eo::Rat|} ⊍ {|eo::Rat|}) (T ⊍ U) (@{|eo::eq|} U {|eo::Rat|} y (@{|eo::to_q|} U y)) (@{|eo::mul|} {|eo::Rat|} {|eo::Rat|} (@{|eo::to_q|} T x) (@{|eo::to_q|} U y)) (@{|eo::mul|} T U x y));
