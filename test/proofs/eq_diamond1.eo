
(declare-const U Type)
(declare-const x0 U)
(define @t1 () (= x0 x0))
(define @t2 () (not @t1))
(define @t3 () (not true))
(assume @p1 @t2)
(step @p2 (= @t3 false) :rule evaluate :args (@t3))
(step @p3 (= @t1 true) :rule eq-refl :args (x0))
(step @p4 (= @t2 @t3) :rule cong :premises (@p3) :args (@t2))
(step @p5 (= @t2 false) :rule trans :premises (@p4 @p2))
(step @p6 false :rule eq_resolve :premises (@p1 @p5))

