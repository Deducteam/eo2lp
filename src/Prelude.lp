require open Stdlib.HOL Stdlib.Bool;

require open Stdlib.String;
require open Stdlib.Z;

// !! the Set of all Eunoia types. !!
symbol {|eo::Type|} : Set;
rule Ļ„ {|eo::Type|} ā†Ŗ Set;

// Core types - use Stdlib types where possible
symbol Bool : Ļ„ {|eo::Type|}; rule Ļ„ Bool ā†Ŗ š¯”¹;

// Proof type: Proof F is the type of proofs of formula F
injective symbol Proof : Ļ„ Bool ā†’ TYPE;

// dependent arrow {|eo::Type|} for quoting
symbol ā¤³d (T : Ļ„ {|eo::Type|}) : Ļ„ (T ā¤³ {|eo::Type|}) ā†’ Ļ„ {|eo::Type|};
notation ā¤³d infix right 5;
rule Ļ„ ($T ā¤³d $F) ā†Ŗ (Ī  x : Ļ„ $T, Ļ„ ($F x));

// higher-order application (eo::_).
injective symbol APP [a b] : Ļ„ (a ā¤³ b) ā†’ Ļ„ a ā†’ Ļ„ b;

// inlined typechecking (eo::as).
symbol {|eo::as|} (a : Set) (x : Ļ„ a) : Ļ„ a;
rule {|eo::as|} _ $x ā†Ŗ $x;

// type-level ite.
sequential symbol ?? : š¯”¹ ā†’ Set ā†’ Set ā†’ Set;
rule ?? _ $x $x ā†Ŗ $x
with ?? true $x _ ā†Ŗ $x
with ?submitted? false _ $y ā†Ŗ $y;

// ---- ARITHMETIC -----------------------------
// Arithmetic symbols
//  (e.g., eo::add, eo::mul, eo::neg, eo::is_neg, eo::gt,
//         eo::is_z, eo::to_z, eo::zdiv, eo::zmod)
// are generated by (declare-consts <numeral> Int).

// ---- LOGIC ----------------------------------------

// `(eo::is_bool t)`: Return true if t is a boolean value.
sequential symbol {|eo::is_bool|} [T : Set]: Ļ„ (T ā¤³ Bool);
rule {|eo::is_bool|} [Bool] true ā†Ŗ true
with {|eo::is_bool|} [Bool] false ā†Ŗ true
with {|eo::is_bool|} _ ā†Ŗ false;

// `(eo::and t1 t2)`:
sequential symbol {|eo::and|} : Ļ„ (Bool ā¤³ Bool ā¤³ Bool);
rule {|eo::and|} true true ā†Ŗ true
with {|eo::and|} _ _ ā†Ŗ false;

// `(eo::or t1 t2)`:
sequential symbol {|eo::or|} : Ļ„ (Bool ā¤³ Bool ā¤³ Bool);
rule {|eo::or|} true _ ā†Ŗ true
with {|eo::or|} _ true ā†Ŗ true
with {|eo::or|} false false ā†Ŗ false;

// `(eo::not t1)`:
sequential symbol {|eo::not|} : Ļ„ (Bool ā¤³ Bool);
rule {|eo::not|} true ā†Ŗ false
with {|eo::not|} false ā†Ŗ true;

// `(eo::xor t1 t2)`:
sequential symbol {|eo::xor|} : Ļ„ (Bool ā¤³ Bool ā¤³ Bool);
// boolean xor.
rule {|eo::xor|} true true ā†Ŗ false
with {|eo::xor|} true false ā†Ŗ true
with {|eo::xor|} false true ā†Ŗ true
with {|eo::xor|} false false ā†Ŗ false;

// `(eo::ite t1 t2 t3)`:
// Returns `t2` if `t1` is `true`, `t3` if `t1` is `false`,
// and is not evaluated otherwise.
// Note that the branches of this term are only evaluated
// if they are the return term.
sequential symbol {|eo::ite|} [U T : Set] (b : Ļ„ Bool) : Ļ„ (U ā¤³ T ā¤³ (?? b U T));
rule {|eo::ite|} true $x _ ā†Ŗ $x
with {|eo::ite|} false _ $y ā†Ŗ $y;

// `(eo::eq t1 t2)`:
//  If `t1` and `t2` are ground values, return:
//  - `true` if `t1` is (syntactically) equal to `t2`,
//  - `false` otherwise.
//  If either `t1` or `t2` is non-ground, do not evaluate.
sequential symbol {|eo::eq|} [T : Set] [S : Set] : Ļ„ (T ā¤³ S ā¤³ Bool);
rule {|eo::eq|} $x $x ā†Ŗ true
with {|eo::eq|} _ _ ā†Ŗ false;



// ----- MISC --------------------------------------------



// `(eo::requires t1 t2 t3)`:
//  Return `t3` if `(eo::is_eq t1 t2)` evaluates to `true`.
//  Otherwise, do not evl. Note that `t3` may be non-ground.
sequential symbol {|eo::requires|} [T U V]
  (x : Ļ„ T) (y : Ļ„ U) (z : Ļ„ V) : Ļ„ V;
rule {|eo::requires|} $x $x $z ā†Ŗ $z;

// `(eo::is_ok t)`:
// Return true if `t` is a value, and false otherwise.
// If `t` is not ground, do not evaluate.
sequential symbol {|eo::is_ok|} [T : Set]: Ļ„ (T ā¤³ Bool);

// `(eo::hash t1)`:
// If `t1` is a value, return a numeral unique to `t1`.
sequential symbol {|eo::hash|} [T U : Set]: Ļ„ (T ā¤³ U);

// `(eo::cmp t1 t2)`: Equivalent to `(eo::is_neg (eo::add (eo::neg (eo::hash t1)) (eo::hash t2)))`.
// Note that this method corresponds to an arbitrary total order on terms.
sequential symbol {|eo::cmp|} [T : Set] [U : Set]: Ļ„ (T ā¤³ U ā¤³ Bool);

// `(eo::compare t1 t2)`:
// Compares two terms and returns -1, 0, or 1.
// similar to eo::cmp but returns an integer instead of a boolean.
sequential symbol {|eo::compare|} [T U V : Set]: Ļ„ (T ā¤³ U ā¤³ V);

// `(eo::is_eq t1 t2)`,
//  equivalent to:
//    `(eo::ite (eo::and (eo::is_ok t) (eo::is_ok s))
//       (eo::eq s t) false)`
sequential symbol {|eo::is_eq|} [T1 T2]: Ļ„ (T1 ā¤³ T2 ā¤³ Bool);

// -------- TYPES & VRIBLE BINDING -------------------------------
// `(eo::typeof t1)`:
// If `t1` is a value, return the type of `t1` if its type is ground.
sequential symbol {|eo::typeof|} [T : Set]: Ļ„ (T ā¤³ {|eo::Type|});
rule {|eo::typeof|} [$T] _ ā†Ŗ $T;

// `(eo::var t1 t2)`:
// If `t1` is a string value and `t2` is a ground type, this
// returns the variable whose name is `t1` and whose type is `t2`.
sequential symbol {|eo::var|} [S]
  (s : Ļ„ S) (T : Ļ„ {|eo::Type|}) : Ļ„ T;

// `(eo::is_var t)`:
// Equivalent to
//`(eo::is_eq (eo::var (eo::nameof t) (eo::typeof t)) t)`.
sequential symbol {|eo::is_var|} [T : Set]: Ļ„ (T ā¤³ Bool);
rule {|eo::is_var|} ({|eo::var|} [string] _ _) ā†Ŗ true
with {|eo::is_var|} _          ā†Ŗ false;


// `(eo::nameof t1)`:
//  If `t1` is a ground constant or variable, this returns
// the name of `t1`, i.e. the string corresponding to the
// symbol it was declared with.
sequential symbol {|eo::nameof|} [T S]: Ļ„ (T ā¤³ S);
rule {|eo::nameof|} [_] [string] ({|eo::var|} [string] $s _) ā†Ŗ $s;




// ---- LISTS & N-ARY OPS ----
// All operations work directly on n-ary terms: (f x (f y (f z nil)))
// Three cases: multi-element APP (APP $f $x) $xs, nil terminator, singleton bare term.

// `(eo::nil f T)`:
//  If `f` is :right-assoc-nil and `T` is a ground type,
//  return the nil terminator specialized for `T`.
sequential symbol {|eo::nil|} [T1 T2]
    (f : Ļ„ (T1 ā¤³ T2 ā¤³ T2))
    (T : Ļ„ {|eo::Type|}) : Ļ„ T;

// `(eo::cons f t1 t2)`:
// If `t2` is an `f`-list, return `(f t1 t2)`.
sequential symbol {|eo::cons|} [U : Set] [T : Set] :
	Ļ„ ((U ā¤³ T ā¤³ T) ā¤³ U ā¤³ T ā¤³ T);
rule {|eo::cons|} $f $x (APP (APP $f $y) $ys)
  ā†Ŗ APP (APP $f $x) (APP (APP $f $y) $ys)
with {|eo::cons|} [_] [$T] $f $x $xs
  ā†Ŗ {|eo::requires|} $xs ({|eo::nil|} $f $T) (APP (APP $f $x) $xs);

// `(eo::list_concat f t1 t2)`: Concatenate two f-lists.
sequential symbol {|eo::list_concat|}
  [T1 T2] (f : Ļ„ (T1 ā¤³ T2 ā¤³ T2)) :
  Ļ„ (T2 ā¤³ T2 ā¤³ T2);
rule {|eo::list_concat|} $f (APP (APP $f $x) $xs) $ys
  ā†Ŗ APP (APP $f $x) ({|eo::list_concat|} $f $xs $ys)
with {|eo::list_concat|} [_] [$T2] $f $x $ys
  ā†Ŗ {|eo::requires|} $x ({|eo::nil|} $f $T2) $ys;

// NOTE: eo::list_len, eo::list_nth, eo::list_find are generated
// in enc_ltrl_num (when processing declare-consts <numeral> Int)
// because they depend on the integer representation (of_Z).

// `(eo::list_mem f t1 t2)`: Check if element is in an f-list.
sequential symbol {|eo::list_mem|} [T1 T2] (f : Ļ„ (T1 ā¤³ T2 ā¤³ T2)) : Ļ„ (T2 ā¤³ T1 ā¤³ Bool);
rule {|eo::list_mem|} $f (APP (APP $f $y) $ys) $x
  ā†Ŗ {|eo::ite|} ({|eo::eq|} $x $y) true ({|eo::list_mem|} $f $ys $x)
with {|eo::list_mem|} [_] [$T2] $f $xs $x
  ā†Ŗ {|eo::ite|} ({|eo::eq|} $xs ({|eo::nil|} $f $T2)) false ({|eo::eq|} $xs $x);

// `(eo::list_rev f t1)`: Reverse an f-list.
sequential symbol list_rev_acc [T1 T2]
  (f : Ļ„ (T1 ā¤³ T2 ā¤³ T2)) : Ļ„ (T2 ā¤³ T2 ā¤³ T2);
rule list_rev_acc $f (APP (APP $f $x) $xs) $acc
  ā†Ŗ list_rev_acc $f $xs (APP (APP $f $x) $acc)
with list_rev_acc [_] [$T2] $f $x $acc
  ā†Ŗ {|eo::requires|} $x ({|eo::nil|} $f $T2) $acc;

sequential symbol {|eo::list_rev|} [T1 T2]
  (f : Ļ„ (T1 ā¤³ T2 ā¤³ T2)) : Ļ„ (T2 ā¤³ T2);
rule {|eo::list_rev|} [_] [$T2] $f (APP (APP $f $x) $xs)
  ā†Ŗ list_rev_acc $f $xs (APP (APP $f $x) ({|eo::nil|} $f $T2))
with {|eo::list_rev|} _ $x ā†Ŗ $x;

// `(eo::list_erase f t1 t2)`: Remove first occurrence of element from f-list.
sequential symbol {|eo::list_erase|} [T1 T2] (f : Ļ„ (T1 ā¤³ T2 ā¤³ T2)) : Ļ„ (T2 ā¤³ T1 ā¤³ T2);
rule {|eo::list_erase|} $f (APP (APP $f $y) $ys) $x
  ā†Ŗ {|eo::ite|} ({|eo::eq|} $x $y) $ys (APP (APP $f $y) ({|eo::list_erase|} $f $ys $x))
with {|eo::list_erase|} [_] [$T2] $f $xs $x
  ā†Ŗ {|eo::ite|} ({|eo::eq|} $xs ({|eo::nil|} $f $T2)) $xs
     ({|eo::ite|} ({|eo::eq|} $xs $x) ({|eo::nil|} $f $T2) $xs);

// `(eo::list_erase_all f t1 t2)`: Remove all occurrences of element from f-list.
sequential symbol {|eo::list_erase_all|} [T1 T2] (f : Ļ„ (T1 ā¤³ T2 ā¤³ T2)) : Ļ„ (T2 ā¤³ T1 ā¤³ T2);
rule {|eo::list_erase_all|} $f (APP (APP $f $y) $ys) $x
  ā†Ŗ {|eo::ite|} ({|eo::eq|} $x $y)
     ({|eo::list_erase_all|} $f $ys $x)
     (APP (APP $f $y) ({|eo::list_erase_all|} $f $ys $x))
with {|eo::list_erase_all|} [_] [$T2] $f $xs $x
  ā†Ŗ {|eo::ite|} ({|eo::eq|} $xs ({|eo::nil|} $f $T2)) $xs
     ({|eo::ite|} ({|eo::eq|} $xs $x) ({|eo::nil|} $f $T2) $xs);

// `(eo::list_setof f t1)`: Deduplicate f-list (keep first occurrence).
sequential symbol {|eo::list_setof|} [T1 T2] (f : Ļ„ (T1 ā¤³ T2 ā¤³ T2)) : Ļ„ (T2 ā¤³ T2);
rule {|eo::list_setof|} $f (APP (APP $f $x) $xs)
  ā†Ŗ APP (APP $f $x) ({|eo::list_setof|} $f ({|eo::list_erase_all|} $f $xs $x))
with {|eo::list_setof|} _ $x ā†Ŗ $x;

// `(eo::list_minclude f t1 t2)`: Multiset inclusion via iterative removal.
sequential symbol minclude_aux [T1 T2]
  (f : Ļ„ (T1 ā¤³ T2 ā¤³ T2)) : Ļ„ (T2 ā¤³ T2 ā¤³ Bool);
rule minclude_aux $f (APP (APP $f $x) $xs) $ys
  ā†Ŗ {|eo::ite|} ({|eo::list_mem|} $f $ys $x)
     (minclude_aux $f $xs ({|eo::list_erase|} $f $ys $x))
     false
with minclude_aux [_] [$T2] $f $x _
  ā†Ŗ {|eo::requires|} $x ({|eo::nil|} $f $T2) true;

sequential symbol {|eo::list_minclude|} [T1 T2] (f : Ļ„ (T1 ā¤³ T2 ā¤³ T2)) : Ļ„ (T2 ā¤³ T2 ā¤³ Bool);
rule {|eo::list_minclude|} $f $xs $ys ā†Ŗ minclude_aux $f $xs $ys;

// `(eo::list_meq f t1 t2)`: Multiset equality.
sequential symbol {|eo::list_meq|} [T1 T2] (f : Ļ„ (T1 ā¤³ T2 ā¤³ T2)) : Ļ„ (T2 ā¤³ T2 ā¤³ Bool);
rule {|eo::list_meq|} $f $xs $ys
  ā†Ŗ {|eo::and|}
     ({|eo::list_minclude|} $f $xs $ys)
     ({|eo::list_minclude|} $f $ys $xs);

// `(eo::list_diff f t1 t2)`: Multiset difference.
sequential symbol list_diff_aux [T1 T2]
  (f : Ļ„ (T1 ā¤³ T2 ā¤³ T2)) : Ļ„ (T2 ā¤³ T2 ā¤³ T2);
rule list_diff_aux $f (APP (APP $f $x) $xs) $ys
  ā†Ŗ {|eo::ite|} ({|eo::list_mem|} $f $ys $x)
     (list_diff_aux $f $xs ({|eo::list_erase|} $f $ys $x))
     (APP (APP $f $x) (list_diff_aux $f $xs $ys))
with list_diff_aux [_] [$T2] $f $x _
  ā†Ŗ {|eo::requires|} $x ({|eo::nil|} $f $T2) ({|eo::nil|} $f $T2);

sequential symbol {|eo::list_diff|} [T1 T2]
  (f : Ļ„ (T1 ā¤³ T2 ā¤³ T2)) : Ļ„ (T2 ā¤³ T2 ā¤³ T2);
rule {|eo::list_diff|} $f $xs $ys ā†Ŗ list_diff_aux $f $xs $ys;

// `(eo::list_inter f t1 t2)`: Multiset intersection.
sequential symbol list_inter_aux [T1 T2]
  (f : Ļ„ (T1 ā¤³ T2 ā¤³ T2)) : Ļ„ (T2 ā¤³ T2 ā¤³ T2);
rule list_inter_aux $f (APP (APP $f $x) $xs) $ys
  ā†Ŗ {|eo::ite|} ({|eo::list_mem|} $f $ys $x)
     (APP (APP $f $x) (list_inter_aux $f $xs ({|eo::list_erase|} $f $ys $x)))
     (list_inter_aux $f $xs $ys)
with list_inter_aux [_] [$T2] $f $x _
  ā†Ŗ {|eo::requires|} $x ({|eo::nil|} $f $T2) ({|eo::nil|} $f $T2);

sequential symbol {|eo::list_inter|} [T1 T2]
  (f : Ļ„ (T1 ā¤³ T2 ā¤³ T2)) : Ļ„ (T2 ā¤³ T2 ā¤³ T2);
rule {|eo::list_inter|} $f $xs $ys ā†Ŗ list_inter_aux $f $xs $ys;

// `(eo::list_singleton_elim f t1)`: Extract element from singleton f-list.
sequential symbol {|eo::list_singleton_elim|} [T] (f : Ļ„ (T ā¤³ T ā¤³ T)) : Ļ„ (T ā¤³ T);
rule {|eo::list_singleton_elim|} [$T] $f (APP (APP $f $x) $xs)
  ā†Ŗ {|eo::ite|} ({|eo::eq|} $xs ({|eo::nil|} $f $T))
     $x (APP (APP $f $x) $xs)
with {|eo::list_singleton_elim|} _ $x ā†Ŗ $x;


// ------ eo::List --- heterogeneous lists ----------------
symbol {|eo::List|} : Ļ„ {|eo::Type|};
sequential symbol {|eo::List::nil|} : Ļ„ {|eo::List|};
sequential symbol {|eo::List::cons|} [T : Set]: Ļ„ (T ā¤³ {|eo::List|} ā¤³ {|eo::List|});

// eo::List::concat - specialized concat for heterogeneous eo::List
// No implicit type params, so can be used in rewrite rule LHS/RHS
sequential symbol {|eo::List::concat|} :
  Ļ„ ({|eo::List|} ā¤³ {|eo::List|} ā¤³ {|eo::List|});
rule {|eo::List::concat|} {|eo::List::nil|} $ys ā†Ŗ $ys
with {|eo::List::concat|} (APP (APP ({|eo::List::cons|} [$T]) $x) $xs) $ys
  ā†Ŗ APP (APP ({|eo::List::cons|} [$T]) $x) ({|eo::List::concat|} $xs $ys);

sequential symbol {|eo::List::find|} [T U] :
  Ļ„ ({|eo::List|} ā¤³ T ā¤³ U);

// eo::List::nth_type - get type of nth element.
sequential symbol {|eo::List::nth_type|} [Z] :
  Ļ„ ({|eo::List|} ā¤³ Z ā¤³ {|eo::Type|});
rule {|eo::List::nth_type|} [int]
  (APP (APP ({|eo::List::cons|} [$T]) _) _) 0
  ā†Ŗ $T
with {|eo::List::nth_type|} [int]
  (APP (APP ({|eo::List::cons|} [_]) _) $xs) $n
  ā†Ŗ {|eo::List::nth_type|} $xs ($n + -1);

// eo::List::nth - get nth element of heterogeneous eo::List
// Returns the element at index i with dependently-typed return.
sequential symbol {|eo::List::nth|} [Z]
  (T : Set) (xs : Ļ„ {|eo::List|}) (n : Ļ„ Z)
  : Ļ„ (T);
rule {|eo::List::nth|} [int] $T
  (APP (APP ({|eo::List::cons|} [$T]) $x) _) 0
  ā†Ŗ $x
with {|eo::List::nth|} [int] $T
  (APP (APP ({|eo::List::cons|} [_]) _) $xs) $n
  ā†Ŗ {|eo::List::nth|} $T $xs ($n + -1);
