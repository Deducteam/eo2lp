require open Stdlib.HOL Stdlib.Bool;

require open Stdlib.String;
require open Stdlib.Z;
require open Stdlib.Q;

// !! the Set of all Eunoia types. !!
symbol {|eo::Type|} : Set;
rule τ {|eo::Type|} ↪ Set;

// Core types - use Stdlib types where possible
symbol Bool : τ {|eo::Type|}; rule τ Bool ↪ 𝔹;

// Proof type: Proof F is the type of proofs of formula F
injective symbol Proof : τ Bool → TYPE;

// dependent arrow {|eo::Type|} for quoting
symbol ⤳d (T : τ {|eo::Type|}) : τ (T ⤳ {|eo::Type|}) → τ {|eo::Type|};
notation ⤳d infix right 5;
rule τ ($T ⤳d $F) ↪ (Π x : τ $T, τ ($F x));

// higher-order application (eo::_).
injective symbol APP [a b] : τ (a ⤳ b) → τ a → τ b;

// infix alias for APP.
symbol ⋅ [a b] (f : τ (a ⤳ b)) (x : τ a) ≔ APP f x;
notation ⋅ infix left 20;


// inlined typechecking (eo::as).
symbol {|eo::as|} (a : Set) (x : τ a) : τ a;
rule {|eo::as|} _ $x ↪ $x;

// type-level ite.
sequential symbol ?? : 𝔹 → Set → Set → Set;
rule ?? _ $x $x ↪ $x
with ?? true $x _ ↪ $x
with ?? false _ $y ↪ $y;

// ---- ARITHMETIC -----------------------------
// Polymorphic arithmetic builtins.
// Computation rules specialized at each type (Int, Real, ...)
// are added by enc_numerals.ml when processing declare-consts.

sequential symbol {|eo::add|} [a : Set] : τ (a ⤳ (a ⤳ a));
sequential symbol {|eo::mul|} [a : Set] : τ (a ⤳ (a ⤳ a));
sequential symbol {|eo::neg|} [a : Set] : τ (a ⤳ a);
sequential symbol {|eo::is_neg|} [a : Set] : τ (a ⤳ Bool);
sequential symbol {|eo::gt|} [a : Set] : τ (a ⤳ (a ⤳ Bool));
sequential symbol {|eo::is_z|} [T : Set] : τ (T ⤳ Bool);
// eo::to_z is generated by declare-consts <numeral> with type [T] : τ (T ⤳ Int)
sequential symbol {|eo::zdiv|} [a : Set] : τ (a ⤳ (a ⤳ a));
sequential symbol {|eo::zmod|} [a : Set] : τ (a ⤳ (a ⤳ a));
// eo::to_q, eo::is_q, eo::qdiv are generated by declare-consts <rational> with concrete Real return types

// Rational arithmetic on Frac. Used by eo::add/mul/neg/qdiv rules at Real.
rule qadd (Frac $a $b) (Frac $c $d) ↪ Frac ($a * $d + $c * $b) ($b * $d);
rule qmul (Frac $a $b) (Frac $c $d) ↪ Frac ($a * $c) ($b * $d);
rule qdiv (Frac $a $b) (Frac $c $d) ↪ Frac ($a * $d) ($b * $c);
// qneg has wrong stdlib type (ℚ → ℚ → ℚ), so we define negation directly:
symbol qneg1 : ℚ → ℚ;
rule qneg1 (Frac $a $b) ↪ Frac (— $a) $b;

// Type-dispatched zero and one for polymorphic nil terminators.
// Rules (e.g. $zero Int ↪ of_Z 0) are added by enc_numerals.ml.
sequential symbol {|$zero|} (T : Set) : τ T;
sequential symbol {|$one|} (T : Set) : τ T;

// ---- LOGIC ----------------------------------------

// `(eo::is_bool t)`: Return true if t is a boolean value.
sequential symbol {|eo::is_bool|} [T : Set]: τ (T ⤳ Bool);
rule {|eo::is_bool|} [Bool] true ↪ true
with {|eo::is_bool|} [Bool] false ↪ true
with {|eo::is_bool|} _ ↪ false;

// `(eo::and t1 t2)`:
sequential symbol {|eo::and|} : τ (Bool ⤳ Bool ⤳ Bool);
rule {|eo::and|} true true ↪ true
with {|eo::and|} _ _ ↪ false;

// `(eo::or t1 t2)`:
sequential symbol {|eo::or|} : τ (Bool ⤳ Bool ⤳ Bool);
rule {|eo::or|} true _ ↪ true
with {|eo::or|} _ true ↪ true
with {|eo::or|} false false ↪ false;

// `(eo::not t1)`:
sequential symbol {|eo::not|} : τ (Bool ⤳ Bool);
rule {|eo::not|} true ↪ false
with {|eo::not|} false ↪ true;

// `(eo::xor t1 t2)`:
sequential symbol {|eo::xor|} : τ (Bool ⤳ Bool ⤳ Bool);
// boolean xor.
rule {|eo::xor|} true true ↪ false
with {|eo::xor|} true false ↪ true
with {|eo::xor|} false true ↪ true
with {|eo::xor|} false false ↪ false;

// `(eo::ite t1 t2 t3)`:
// Returns `t2` if `t1` is `true`, `t3` if `t1` is `false`,
// and is not evaluated otherwise.
// Note that the branches of this term are only evaluated
// if they are the return term.
sequential symbol {|eo::ite|} [U T : Set] (b : τ Bool) : τ (U ⤳ T ⤳ (?? b U T));
rule {|eo::ite|} true $x _ ↪ $x
with {|eo::ite|} false _ $y ↪ $y;

// `(eo::eq t1 t2)`:
//  If `t1` and `t2` are ground values, return:
//  - `true` if `t1` is (syntactically) equal to `t2`,
//  - `false` otherwise.
//  If either `t1` or `t2` is non-ground, do not evaluate.
sequential symbol {|eo::eq|} [T : Set] [S : Set] : τ (T ⤳ S ⤳ Bool);
rule {|eo::eq|} $x $x ↪ true
with {|eo::eq|} _ _ ↪ false;



// ----- MISC --------------------------------------------



// `(eo::requires t1 t2 t3)`:
//  Return `t3` if `(eo::is_eq t1 t2)` evaluates to `true`.
//  Otherwise, do not evl. Note that `t3` may be non-ground.
sequential symbol {|eo::requires|} [T U V]
  (x : τ T) (y : τ U) (z : τ V) : τ V;
rule {|eo::requires|} $x $x $z ↪ $z;

// `(eo::is_ok t)`:
// Return true if `t` is a value, and false otherwise.
// If `t` is not ground, do not evaluate.
sequential symbol {|eo::is_ok|} [T : Set]: τ (T ⤳ Bool);

// `(eo::hash t1)`:
// If `t1` is a value, return a numeral unique to `t1`.
sequential symbol {|eo::hash|} [T U : Set]: τ (T ⤳ U);

// `(eo::cmp t1 t2)`: Equivalent to `(eo::is_neg (eo::add (eo::neg (eo::hash t1)) (eo::hash t2)))`.
// Note that this method corresponds to an arbitrary total order on terms.
sequential symbol {|eo::cmp|} [T : Set] [U : Set]: τ (T ⤳ U ⤳ Bool);

// `(eo::compare t1 t2)`:
// Compares two terms and returns -1, 0, or 1.
// similar to eo::cmp but returns an integer instead of a boolean.
sequential symbol {|eo::compare|} [T U V : Set]: τ (T ⤳ U ⤳ V);

// `(eo::is_eq t1 t2)`,
//  equivalent to:
//    `(eo::ite (eo::and (eo::is_ok t) (eo::is_ok s))
//       (eo::eq s t) false)`
sequential symbol {|eo::is_eq|} [T1 T2]: τ (T1 ⤳ T2 ⤳ Bool);

// -------- TYPES & VRIBLE BINDING -------------------------------
// `(eo::typeof t1)`:
// If `t1` is a value, return the type of `t1` if its type is ground.
sequential symbol {|eo::typeof|} [T : Set]: τ (T ⤳ {|eo::Type|});
rule {|eo::typeof|} [$T] _ ↪ $T;

// `(eo::var t1 t2)`:
// If `t1` is a string value and `t2` is a ground type, this
// returns the variable whose name is `t1` and whose type is `t2`.
sequential symbol {|eo::var|} [S]
  (s : τ S) (T : τ {|eo::Type|}) : τ T;

// `(eo::is_var t)`:
// Equivalent to
//`(eo::is_eq (eo::var (eo::nameof t) (eo::typeof t)) t)`.
sequential symbol {|eo::is_var|} [T : Set]: τ (T ⤳ Bool);
rule {|eo::is_var|} ({|eo::var|} [string] _ _) ↪ true
with {|eo::is_var|} _          ↪ false;


// `(eo::nameof t1)`:
//  If `t1` is a ground constant or variable, this returns
// the name of `t1`, i.e. the string corresponding to the
// symbol it was declared with.
sequential symbol {|eo::nameof|} [T S]: τ (T ⤳ S);
rule {|eo::nameof|} [_] [string] ({|eo::var|} [string] $s _) ↪ $s;



// ------ eo::List --- heterogeneous lists ----------------
symbol {|eo::List|} : τ {|eo::Type|};
sequential symbol {|eo::List::nil|} : τ {|eo::List|};
sequential symbol {|eo::List::cons|} [T : Set]: τ (T ⤳ {|eo::List|} ⤳ {|eo::List|});

// eo::List::concat - specialized concat for heterogeneous eo::List
// No implicit type params, so can be used in rewrite rule LHS/RHS
sequential symbol {|eo::List::concat|} :
  τ ({|eo::List|} ⤳ {|eo::List|} ⤳ {|eo::List|});
rule {|eo::List::concat|} {|eo::List::nil|} $ys ↪ $ys
with {|eo::List::concat|} (APP (APP ({|eo::List::cons|} [$T]) $x) $xs) $ys
  ↪ APP (APP ({|eo::List::cons|} [$T]) $x) ({|eo::List::concat|} $xs $ys);

// NOTE: eo::List::find, eo::List::nth, eo::List::nth_type, eo::List::len
// are generated in enc_numerals.ml (when processing declare-consts <numeral> Int)
// because they depend on the integer representation (of_Z).



// ---- LISTS & N-ARY OPS ----
// All operations work directly on n-ary terms: (f x (f y (f z nil)))
// Three cases: multi-element APP (APP $f $x) $xs, nil terminator, singleton bare term.

// `(eo::nil f T)`:
//  If `f` is :right-assoc-nil and `T` is a ground type,
//  return the nil terminator specialized for `T`.
sequential symbol {|eo::nil|} [T1 T2]
    (f : τ (T1 ⤳ T2 ⤳ T2))
    (T : τ {|eo::Type|}) : τ T;

// `(eo::cons f t1 t2)`:
// If `t2` is an `f`-list, return `(f t1 t2)`.
sequential symbol {|eo::cons|} [U : Set] [T : Set] :
	τ ((U ⤳ T ⤳ T) ⤳ U ⤳ T ⤳ T);
rule {|eo::cons|} $f $x (APP (APP $f $y) $ys)
  ↪ APP (APP $f $x) (APP (APP $f $y) $ys)
  with {|eo::cons|} [_] [$T] $f $x $xs
  ↪ {|eo::requires|} $xs ({|eo::nil|} $f $T) (APP (APP $f $x) $xs);

// `(eo::list_concat f t1 t2)`: Concatenate two f-lists.
sequential symbol {|eo::list_concat|}
  [T1 T2] (f : τ (T1 ⤳ T2 ⤳ T2)) :
  τ (T2 ⤳ T2 ⤳ T2);
rule {|eo::list_concat|} $f (APP (APP $f $x) $xs) $ys
  ↪ APP (APP $f $x) ({|eo::list_concat|} $f $xs $ys)
with {|eo::list_concat|} [_] [$T2] $f $x $ys
  ↪ {|eo::requires|} $x ({|eo::nil|} $f $T2) $ys;

// NOTE: eo::list_len, eo::list_nth, eo::list_find are generated
// in enc_ltrl_num (when processing declare-consts <numeral> Int)
// because they depend on the integer representation (of_Z).

// `(eo::list_mem f t1 t2)`: Check if element is in an f-list.
sequential symbol {|eo::list_mem|} [T1 T2] (f : τ (T1 ⤳ T2 ⤳ T2)) : τ (T2 ⤳ T1 ⤳ Bool);
rule {|eo::list_mem|} $f (APP (APP $f $y) $ys) $x
  ↪ {|eo::ite|} ({|eo::eq|} $x $y) true ({|eo::list_mem|} $f $ys $x)
with {|eo::list_mem|} [_] [$T2] $f $xs $x
  ↪ {|eo::ite|} ({|eo::eq|} $xs ({|eo::nil|} $f $T2)) false ({|eo::eq|} $xs $x);

// `(eo::list_rev f t1)`: Reverse an f-list.
sequential symbol list_rev_acc [T1 T2]
  (f : τ (T1 ⤳ T2 ⤳ T2)) : τ (T2 ⤳ T2 ⤳ T2);
rule list_rev_acc $f (APP (APP $f $x) $xs) $acc
  ↪ list_rev_acc $f $xs (APP (APP $f $x) $acc)
with list_rev_acc [_] [$T2] $f $x $acc
  ↪ {|eo::requires|} $x ({|eo::nil|} $f $T2) $acc;

sequential symbol {|eo::list_rev|} [T1 T2]
  (f : τ (T1 ⤳ T2 ⤳ T2)) : τ (T2 ⤳ T2);
rule {|eo::list_rev|} [_] [$T2] $f (APP (APP $f $x) $xs)
  ↪ list_rev_acc $f $xs (APP (APP $f $x) ({|eo::nil|} $f $T2))
with {|eo::list_rev|} _ $x ↪ $x;

// `(eo::list_erase f t1 t2)`: Remove first occurrence of element from f-list.
sequential symbol {|eo::list_erase|} [T1 T2] (f : τ (T1 ⤳ T2 ⤳ T2)) : τ (T2 ⤳ T1 ⤳ T2);
rule {|eo::list_erase|} $f (APP (APP $f $y) $ys) $x
  ↪ {|eo::ite|} ({|eo::eq|} $x $y) $ys (APP (APP $f $y) ({|eo::list_erase|} $f $ys $x))
with {|eo::list_erase|} [_] [$T2] $f $xs $x
  ↪ {|eo::ite|} ({|eo::eq|} $xs ({|eo::nil|} $f $T2)) $xs
     ({|eo::ite|} ({|eo::eq|} $xs $x) ({|eo::nil|} $f $T2) $xs);

// `(eo::list_erase_all f t1 t2)`: Remove all occurrences of element from f-list.
sequential symbol {|eo::list_erase_all|} [T1 T2] (f : τ (T1 ⤳ T2 ⤳ T2)) : τ (T2 ⤳ T1 ⤳ T2);
rule {|eo::list_erase_all|} $f (APP (APP $f $y) $ys) $x
  ↪ {|eo::ite|} ({|eo::eq|} $x $y)
     ({|eo::list_erase_all|} $f $ys $x)
     (APP (APP $f $y) ({|eo::list_erase_all|} $f $ys $x))
with {|eo::list_erase_all|} [_] [$T2] $f $xs $x
  ↪ {|eo::ite|} ({|eo::eq|} $xs ({|eo::nil|} $f $T2)) $xs
     ({|eo::ite|} ({|eo::eq|} $xs $x) ({|eo::nil|} $f $T2) $xs);

// `(eo::list_setof f t1)`: Deduplicate f-list (keep first occurrence).
sequential symbol {|eo::list_setof|} [T1 T2] (f : τ (T1 ⤳ T2 ⤳ T2)) : τ (T2 ⤳ T2);
rule {|eo::list_setof|} $f (APP (APP $f $x) $xs)
  ↪ APP (APP $f $x) ({|eo::list_setof|} $f ({|eo::list_erase_all|} $f $xs $x))
with {|eo::list_setof|} _ $x ↪ $x;

// `(eo::list_minclude f t1 t2)`: Multiset inclusion via iterative removal.
sequential symbol minclude_aux [T1 T2]
  (f : τ (T1 ⤳ T2 ⤳ T2)) : τ (T2 ⤳ T2 ⤳ Bool);
rule minclude_aux $f (APP (APP $f $x) $xs) $ys
  ↪ {|eo::ite|} ({|eo::list_mem|} $f $ys $x)
     (minclude_aux $f $xs ({|eo::list_erase|} $f $ys $x))
     false
with minclude_aux [_] [$T2] $f $x _
  ↪ {|eo::requires|} $x ({|eo::nil|} $f $T2) true;

sequential symbol {|eo::list_minclude|} [T1 T2] (f : τ (T1 ⤳ T2 ⤳ T2)) : τ (T2 ⤳ T2 ⤳ Bool);
rule {|eo::list_minclude|} $f $xs $ys ↪ minclude_aux $f $xs $ys;

// `(eo::list_meq f t1 t2)`: Multiset equality.
sequential symbol {|eo::list_meq|} [T1 T2] (f : τ (T1 ⤳ T2 ⤳ T2)) : τ (T2 ⤳ T2 ⤳ Bool);
rule {|eo::list_meq|} $f $xs $ys
  ↪ {|eo::and|}
     ({|eo::list_minclude|} $f $xs $ys)
     ({|eo::list_minclude|} $f $ys $xs);

// `(eo::list_diff f t1 t2)`: Multiset difference.
sequential symbol list_diff_aux [T1 T2]
  (f : τ (T1 ⤳ T2 ⤳ T2)) : τ (T2 ⤳ T2 ⤳ T2);
rule list_diff_aux $f (APP (APP $f $x) $xs) $ys
  ↪ {|eo::ite|} ({|eo::list_mem|} $f $ys $x)
     (list_diff_aux $f $xs ({|eo::list_erase|} $f $ys $x))
     (APP (APP $f $x) (list_diff_aux $f $xs $ys))
with list_diff_aux [_] [$T2] $f $x _
  ↪ {|eo::requires|} $x ({|eo::nil|} $f $T2) ({|eo::nil|} $f $T2);

sequential symbol {|eo::list_diff|} [T1 T2]
  (f : τ (T1 ⤳ T2 ⤳ T2)) : τ (T2 ⤳ T2 ⤳ T2);
rule {|eo::list_diff|} $f $xs $ys ↪ list_diff_aux $f $xs $ys;

// `(eo::list_inter f t1 t2)`: Multiset intersection.
sequential symbol list_inter_aux [T1 T2]
  (f : τ (T1 ⤳ T2 ⤳ T2)) : τ (T2 ⤳ T2 ⤳ T2);
rule list_inter_aux $f (APP (APP $f $x) $xs) $ys
  ↪ {|eo::ite|} ({|eo::list_mem|} $f $ys $x)
     (APP (APP $f $x) (list_inter_aux $f $xs ({|eo::list_erase|} $f $ys $x)))
     (list_inter_aux $f $xs $ys)
with list_inter_aux [_] [$T2] $f $x _
  ↪ {|eo::requires|} $x ({|eo::nil|} $f $T2) ({|eo::nil|} $f $T2);

sequential symbol {|eo::list_inter|} [T1 T2]
  (f : τ (T1 ⤳ T2 ⤳ T2)) : τ (T2 ⤳ T2 ⤳ T2);
rule {|eo::list_inter|} $f $xs $ys ↪ list_inter_aux $f $xs $ys;

// `(eo::list_singleton_elim f t1)`: Extract element from singleton f-list.
sequential symbol {|eo::list_singleton_elim|} [T] (f : τ (T ⤳ T ⤳ T)) : τ (T ⤳ T);
rule {|eo::list_singleton_elim|} [$T] $f (APP (APP $f $x) $xs)
  ↪ {|eo::ite|} ({|eo::eq|} $xs ({|eo::nil|} $f $T))
     $x (APP (APP $f $x) $xs)
with {|eo::list_singleton_elim|} _ $x ↪ $x;
